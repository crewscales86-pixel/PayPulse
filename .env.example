NODE_ENV=production
PORT=3000
BASE_URL=https://your-paypulse-domain.com
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://user:pass@host:5432/dbname
REQUIRE_POSTGRES_IN_PROD=true

ENABLE_BACKGROUND_JOBS=true
BACKGROUND_JOB_POLL_MS=30000
BACKGROUND_JOB_BATCH_SIZE=10

BACKUP_ENABLED=true
BACKUP_DIR=backups
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14

EMAIL_FROM=PayPulse <support@yourdomain.com>
SUPPORT_EMAIL=support@yourdomain.com
RESEND_API_KEY=re_xxx

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=support@yourdomain.com

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

STRIPE_WEBHOOK_ROUTE_SECRET=
STRIPE_WEBHOOK_SECRET=
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://your-paypulse-domain.com/api/meta/callback
