# PayPulse Environment Variables
# Copy to .env for local dev, or set in Railway dashboard

# Database — set this to use PostgreSQL (Railway provides this automatically)
# If empty, falls back to local SQLite (dev only)
DATABASE_URL=

# JWT secret — MUST change in production
JWT_SECRET=change-me-to-a-random-string

# Base URL of your deployed app (used for webhook URLs)
BASE_URL=http://localhost:3000

# Port (Railway sets this automatically)
PORT=3000
