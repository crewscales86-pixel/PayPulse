# PayPulse Environment Variables
# Copy to .env for local dev, or set in Railway dashboard

# Database — set this to use PostgreSQL (Railway provides this automatically)
# If empty, falls back to local SQLite (dev only)
DATABASE_URL=

# JWT secret — MUST change in production
JWT_SECRET=change-me-to-a-random-string

# Base URL of your deployed app (used for webhook URLs)
BASE_URL=http://localhost:3000

# Stripe webhook route secret used in /webhook/stripe/:secret
STRIPE_WEBHOOK_ROUTE_SECRET=change-me

# Stripe signing secret from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_change_me

# Meta Ads native integration
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v23.0
META_REDIRECT_URI=http://localhost:3000/api/meta/callback

# Optional SMTP config for approval emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@paypulse.local

# Port (Railway sets this automatically)
PORT=3000
